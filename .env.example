# ============================================================================
#  Triality — Environment Configuration
#  Copy this file to .env and modify as needed
# ============================================================================

# Server Configuration
TRIALITY_HOST=127.0.0.1
TRIALITY_PORT=8510

# LLM Integration (required for the Triality Agent)
# The agent uses Replicate-hosted models for natural language routing.
# Get your token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=
TRIALITY_LLM_MODEL=meta/llama-4-maverick-instruct
